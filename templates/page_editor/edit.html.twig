{% extends 'base.html.twig' %}

{% block title %}Edit {{ page.title }} - {{ site.name }}{% endblock %}

{% block stylesheets %}
<style>
:root {
  --editor-bg: #f5f5f5;
  --editor-surface: #ffffff;
  --editor-border: #e0e0e0;
  --editor-primary: #2196F3;
  --editor-hover: #1976D2;
  --editor-text: #333;
  --editor-text-muted: #666;
  --editor-danger: #f44336;
}

body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

.editor-container {
  display: grid;
  grid-template-columns: 280px 1fr 320px;
  height: 100vh;
  background: var(--editor-bg);
}

/* Sidebar - Block Palette */
.block-palette {
  background: var(--editor-surface);
  border-right: 1px solid var(--editor-border);
  overflow-y: auto;
  padding: 20px;
}

.block-palette h3 {
  margin: 0 0 16px;
  font-size: 14px;
  font-weight: 600;
  color: var(--editor-text);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.block-palette-item {
  padding: 12px;
  margin-bottom: 8px;
  background: var(--editor-bg);
  border: 2px dashed var(--editor-border);
  border-radius: 6px;
  cursor: grab;
  transition: all 0.2s;
}

.block-palette-item:hover {
  border-color: var(--editor-primary);
  background: #E3F2FD;
}

.block-palette-item:active {
  cursor: grabbing;
}

.block-palette-item-icon {
  display: inline-block;
  width: 20px;
  text-align: center;
  margin-right: 8px;
}

/* Canvas - Main Editor */
.editor-canvas {
  overflow-y: auto;
  padding: 40px;
}

.canvas-header {
  background: var(--editor-surface);
  padding: 20px;
  margin-bottom: 24px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.canvas-header h1 {
  margin: 0 0 8px;
  font-size: 24px;
}

.canvas-header input {
  width: 100%;
  padding: 8px;
  border: 1px solid var(--editor-border);
  border-radius: 4px;
  font-size: 14px;
}

.canvas-toolbar {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.btn {
  padding: 8px 16px;
  border: none;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-primary {
  background: var(--editor-primary);
  color: white;
}

.btn-primary:hover {
  background: var(--editor-hover);
}

.btn-secondary {
  background: var(--editor-surface);
  color: var(--editor-text);
  border: 1px solid var(--editor-border);
}

.btn-secondary:hover {
  background: var(--editor-bg);
}

/* Block Grid */
.block-grid {
  background: var(--editor-surface);
  min-height: 400px;
  padding: 24px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.block-item {
  position: relative;
  padding: 16px;
  margin-bottom: 16px;
  border: 2px solid var(--editor-border);
  border-radius: 6px;
  background: white;
  transition: all 0.2s;
}

.block-item:hover {
  border-color: var(--editor-primary);
  box-shadow: 0 2px 8px rgba(33, 150, 243, 0.2);
}

.block-item.dragging {
  opacity: 0.5;
  cursor: grabbing;
}

.block-item.drag-over {
  border-color: var(--editor-primary);
  background: #E3F2FD;
}

.block-toolbar {
  position: absolute;
  top: 8px;
  right: 8px;
  display: flex;
  gap: 4px;
  opacity: 0;
  transition: opacity 0.2s;
}

.block-item:hover .block-toolbar {
  opacity: 1;
}

.block-toolbar-btn {
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 4px;
  background: var(--editor-surface);
  color: var(--editor-text);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.block-toolbar-btn:hover {
  background: var(--editor-primary);
  color: white;
}

.block-toolbar-btn.danger:hover {
  background: var(--editor-danger);
}

.block-drag-handle {
  cursor: grab;
  padding: 4px;
  margin-right: 8px;
  color: var(--editor-text-muted);
}

.block-drag-handle:active {
  cursor: grabbing;
}

.block-content {
  margin-top: 8px;
}

.block-type-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--editor-text-muted);
  background: var(--editor-bg);
  padding: 2px 8px;
  border-radius: 3px;
  margin-bottom: 8px;
}

/* Inspector Panel */
.inspector-panel {
  background: var(--editor-surface);
  border-left: 1px solid var(--editor-border);
  padding: 20px;
  overflow-y: auto;
}

.inspector-panel h3 {
  margin: 0 0 16px;
  font-size: 14px;
  font-weight: 600;
  color: var(--editor-text);
}

.inspector-panel.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--editor-text-muted);
  font-size: 14px;
}

/* Modal */
.modal-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}

.modal-overlay.active {
  display: flex;
}

.modal {
  background: var(--editor-surface);
  border-radius: 8px;
  width: 90%;
  max-width: 600px;
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
}

.modal-header {
  padding: 20px;
  border-bottom: 1px solid var(--editor-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h2 {
  margin: 0;
  font-size: 18px;
}

.modal-close {
  width: 32px;
  height: 32px;
  border: none;
  background: none;
  font-size: 24px;
  cursor: pointer;
  color: var(--editor-text-muted);
}

.modal-close:hover {
  color: var(--editor-text);
}

.modal-body {
  padding: 20px;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  padding: 20px;
  border-top: 1px solid var(--editor-border);
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.form-group {
  margin-bottom: 16px;
}

.form-group label {
  display: block;
  margin-bottom: 6px;
  font-size: 14px;
  font-weight: 500;
  color: var(--editor-text);
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 8px;
  border: 1px solid var(--editor-border);
  border-radius: 4px;
  font-size: 14px;
  font-family: inherit;
}

.form-group textarea {
  min-height: 100px;
  resize: vertical;
}

.save-indicator {
  position: fixed;
  bottom: 20px;
  right: 20px;
  padding: 12px 20px;
  background: #4CAF50;
  color: white;
  border-radius: 4px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.save-indicator.show {
  opacity: 1;
}
</style>
{% endblock %}

{% block body %}
<div class="editor-container">
  <!-- Block Palette Sidebar -->
  <aside class="block-palette">
    <h3>Add Blocks</h3>
    
    <div class="block-palette-item" draggable="true" data-block-type="paragraph">
      <span class="block-palette-item-icon">¶</span>
      <span>Paragraph</span>
    </div>
    
    <div class="block-palette-item" draggable="true" data-block-type="heading">
      <span class="block-palette-item-icon">H</span>
      <span>Heading</span>
    </div>
    
    <div class="block-palette-item" draggable="true" data-block-type="image">
      <span class="block-palette-item-icon">🖼</span>
      <span>Image</span>
    </div>
    
    <div class="block-palette-item" draggable="true" data-block-type="link">
      <span class="block-palette-item-icon">🔗</span>
      <span>Link</span>
    </div>
    
    <div class="block-palette-item" draggable="true" data-block-type="list">
      <span class="block-palette-item-icon">≡</span>
      <span>List</span>
    </div>

    <div class="block-palette-item" draggable="true" data-block-type="section">
      <span class="block-palette-item-icon">⬚</span>
      <span>Section</span>
    </div>
  </aside>

  <!-- Main Canvas -->
  <main class="editor-canvas">
    <div class="canvas-header">
      <h1>
        <input 
          type="text" 
          id="pageTitle" 
          value="{{ page.title }}" 
          placeholder="Page Title"
        />
      </h1>
      
      <div class="canvas-toolbar">
        <button class="btn btn-primary" id="savePage">
          💾 Save Page
        </button>
        <button class="btn btn-secondary" id="previewPage">
          👁 Preview
        </button>
        <a href="{{ path('site_dashboard') }}" class="btn btn-secondary">
          ← Back to Dashboard
        </a>
      </div>
    </div>

    <div class="block-grid" id="blockGrid">
      {% for block in pageData.blocktree|default([]) %}
        {% include 'blocks/_block_item.html.twig' with {'block': block, 'index': loop.index0} %}
      {% else %}
        <div class="empty-state" style="text-align: center; padding: 60px 20px; color: var(--editor-text-muted);">
          <p style="font-size: 18px; margin-bottom: 8px;">No blocks yet</p>
          <p style="font-size: 14px;">Drag blocks from the left sidebar to get started</p>
        </div>
      {% endfor %}
    </div>
  </main>

  <!-- Inspector Panel -->
  <aside class="inspector-panel empty" id="inspectorPanel">
    <p>Select a block to configure</p>
  </aside>
</div>

<!-- Block Config Modal -->
<div class="modal-overlay" id="blockConfigModal">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Configure Block</h2>
      <button class="modal-close" onclick="PageEditor.closeModal()">&times;</button>
    </div>
    <div class="modal-body" id="modalBody">
      <!-- Dynamic form content -->
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="PageEditor.closeModal()">Cancel</button>
      <button class="btn btn-primary" id="modalSave">Save Changes</button>
    </div>
  </div>
</div>

<!-- Asset Picker Modal -->
<div class="modal-overlay" id="assetPickerModal">
  <div class="modal">
    <div class="modal-header">
      <h2>Choose Asset</h2>
      <button class="modal-close" onclick="PageEditor.closeAssetPicker()">&times;</button>
    </div>
    <div class="modal-body" id="assetPickerBody">
      <!-- Loaded via AJAX -->
    </div>
  </div>
</div>

<!-- Save Indicator -->
<div class="save-indicator" id="saveIndicator">
  ✓ Saved
</div>

<script>
// Pass data to JavaScript
window.PAGE_DATA = {
  pageId: {{ page.id }},
  blocktree: {{ pageData.blocktree|default([])|json_encode|raw }},
  saveUrl: "{{ path('page_editor_save', {id: page.id}) }}",
  assetBrowseUrl: "{{ path('page_editor_assets_browse', {modal: 1}) }}"
};
</script>
{% endblock %}

{% block javascripts %}
  {{ importmap('page-editor') }}
{% endblock %}
