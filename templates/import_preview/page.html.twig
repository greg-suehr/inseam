<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{{ title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <style>
    body { font: 16px/1.5 system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 2rem auto; max-width: 720px; padding: 0 1rem; }
    h1,h2,h3 { line-height: 1.2; margin: 1.2em 0 .4em; }
    p { margin: .8em 0; }
    img { max-width: 100%; height: auto; display: block; margin: 1rem 0; border-radius: 12px; }
    a { text-decoration: underline; }
    .links a { display: inline-block; margin-right: .75rem; }
    .meta { color:#777; font-size:.9rem; margin-bottom:1rem; }
  </style>
</head>
<body>
  <div class="meta">Preview of {{ url }}</div>

  {% for b in blocks %}
    {% include 'import_preview/blocks/' ~ (b.type|default('unknown')) ~ '.html.twig' ignore missing with { b: b } %}
  {% endfor %}
</body>
</html>
