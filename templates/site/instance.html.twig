{# templates/instance.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_content %}

    {# No site selected: fail safe #}
    {% if not site %}
        <div class="alert alert-warning">
            Select a site to continue.
        </div>
        <div>
            <a class="btn btn-primary"
               href="{{ ea_url()
                    .setDashboard('App\\Controller\\IsHereDashboardController')
                    .setController('App\\Controller\\Admin\\SiteCrudController')
                    .setAction('index')
               }}">
                Go to Sites
            </a>
        </div>
    {% endif %}

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message|raw }}</div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-1">{{ site.name }}</h2>
            <div class="text-muted">
                ID #{{ site.id }}
            </div>
        </div>
    </div>

    {# Quick actions #}
    <div class="row g-3 mb-4">
        <div class="col-auto">
            <a class="btn btn-primary"
               href="{{ ea_url()
                    .setController('App\\Controller\\Admin\\PageCrudController')
                    .setAction('new')
               }}">
                New Page
            </a>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-primary"
               href="{{ ea_url()
                    .setController('App\\Controller\\Admin\\PageCrudController')
                    .setAction('index')
               }}">
                Manage Pages
            </a>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-primary"
               href="{{ ea_url()
                    .setController('App\\Controller\\Admin\\AssetCrudController')
                    .setAction('index')
               }}">
                Manage Assets
            </a>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary"
               href="{{ ea_url()
                    .setDashboard('App\\Controller\\IsHereDashboardController')
                    .setController('App\\Controller\\Admin\\SiteCrudController')
                    .setAction('edit')
                    .setEntityId(site.id)
               }}">
                Edit Site Settings
            </a>
        </div>
    </div>

    {# KPI cards #}
    {% set kpi = {
        pages:   stats.pages   ?? 0,
        blocks:  stats.blocks  ?? 0,
        assets:  stats.assets  ?? 0
    } %}

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted">Pages</div>
                    <div class="display-6 fw-semibold">{{ kpi.pages }}</div>
                    <a class="stretched-link"
                       href="{{ ea_url()
                            .setDashboard('App\\Controller\\IsHereDashboardController')
                            .setController('App\\Controller\\Admin\\PageCrudController')
                            .setAction('index')
                       }}"></a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted">Blocks</div>
                    <div class="display-6 fw-semibold">{{ kpi.blocks }}</div>
                    <a class="stretched-link"
                       href="{{ ea_url()
                            .setDashboard('App\\Controller\\IsHereDashboardController')
                            .setController('App\\Controller\\Admin\\BlockCrudController')
                            .setAction('index')
                       }}"></a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted">Assets</div>
                    <div class="display-6 fw-semibold">{{ kpi.assets }}</div>
                    <a class="stretched-link"
                       href="{{ ea_url()
                            .setDashboard('App\\Controller\\IsHereDashboardController')
                            .setController('App\\Controller\\Admin\\AssetCrudController')
                            .setAction('index')
                       }}"></a>
                </div>
            </div>
        </div>
    </div>

    {# Two-column: recent items + helpful links #}
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong>Recent Pages</strong>
                    <a class="btn btn-sm btn-outline-secondary"
                       href="{{ ea_url()
                            .setDashboard('App\\Controller\\IsHereDashboardController')
                            .setController('App\\Controller\\Admin\\PageCrudController')
                            .setAction('index')
                       }}">View all</a>
                </div>
                <div class="card-body p-0">
                    {% if latestPages is defined and latestPages|length %}
                        <div class="list-group list-group-flush">
                            {% for p in latestPages %}
                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                   href="{{ ea_url()
                                        .setDashboard('App\\Controller\\IsHereDashboardController')
                                        .setController('App\\Controller\\Admin\\PageCrudController')
                                        .setAction('edit')
                                        .setEntityId(p.id)
                                   }}">
                                    <span class="text-truncate">{{ p.title }}</span>
                                    <small class="text-muted">{{ p.updatedAt ? p.updatedAt|date('Y-m-d H:i') : '' }}</small>
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="p-3 text-muted">No pages yet.</div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header"><strong>Shortcuts</strong></div>
                <div class="card-body">
                    <div class="vstack gap-2">
                        <a class="btn btn-outline-primary w-100"
                           href="{{ ea_url()
                                .setDashboard('App\\Controller\\IsHereDashboardController')
                                .setController('App\\Controller\\Admin\\BlockCrudController')
                                .setAction('new')
                           }}">
                            New Block
                        </a>
                        <a class="btn btn-outline-primary w-100"
                           href="{{ ea_url()
                                .setDashboard('App\\Controller\\IsHereDashboardController')
                                .setController('App\\Controller\\Admin\\AssetCrudController')
                                .setAction('new')
                           }}">
                            Upload Asset
                        </a>
                        <a class="btn btn-outline-secondary w-100"
                           href="{{ ea_url()
                                .setDashboard('App\\Controller\\IsHereDashboardController')
                                .setController('App\\Controller\\Admin\\SiteCrudController')
                                .setAction('index')
                           }}">
                            Switch Site
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
